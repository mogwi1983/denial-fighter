# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional production demo flags
SAVE_GENERATED_APPEALS=false
ALLOW_PUBLIC_APPEAL_HISTORY=false

# Pilot waitlist mailto on /landing (optional; public — use a role inbox, not personal PHI)
# NEXT_PUBLIC_WAITLIST_EMAIL=pilot-inbox@example.com

# Appeal history API: production requires sign-in unless ALLOW_PUBLIC_APPEAL_HISTORY=true.
# Development allows anonymous history unless APPEALS_REQUIRE_LOGIN=true.
# APPEALS_REQUIRE_LOGIN=false
